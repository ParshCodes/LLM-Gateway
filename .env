# Copy this to .env and adjust values before running docker compose

# ── Model ─────────────────────────────────────────────────────────────────
MODEL_NAME=llama3.2:1b          # any model name supported by Ollama

# ── Gateway: rate limiting ─────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60          # max requests per client per window
RATE_LIMIT_WINDOW=60            # window length in seconds

# ── Gateway: concurrency / queue ───────────────────────────────────────────
MAX_CONCURRENT_REQUESTS=4       # simultaneous upstream calls (tune to GPU/CPU)
MAX_QUEUE_SIZE=50               # max requests waiting before 503
QUEUE_TIMEOUT=30                # seconds a queued request will wait

# ── Gateway: misc ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# ── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin          # change before exposing publicly
